# Bundler
/.bundle

# Logs and tempfiles
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/.keep

# Uploaded files in development
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# Compiled assets / node
/node_modules
/app/assets/builds/*
!/app/assets/builds/.keep
/public/assets

# Rails master key - decrypts config/credentials.yml.enc, never commit this
/config/master.key

# OS / editor
.DS_Store
.vscode/
